{
  "name": "apps-extension",
  "displayName": "Apps extension",
  "version": "0.0.1",
  "description": "Go back, rewind. ",
  "author": "mjk",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@plasmohq/storage": "^1.15.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "host_permissions": [
      "https://*/*", "https://memento-mjk1.vercel.app/*"
    ],
    "commands": {
      "start-voice-record": {
        "suggested_key": {
          "default": "Alt+Shift+V",
          "mac": "Alt+Shift+V"
        },
        "description": "Start Voice Recording"
      },
      "stop-voice-record": {
        "suggested_key": {
          "default": "Alt+Shift+X",
          "mac": "Alt+Shift+X"
        },
        "description": "Stop Voice Recording"
      }
    },
    "permissions": [
      "activeTab",
      "audio",
      "offscreen",
      "storage",
      "tabs"
    ]
  }
}
